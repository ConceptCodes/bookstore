{
  "name": "book-store",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tailwindcss/postcss": "^4.3.1",
      "@types/node": "^24.0.0",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0",
      "ai": "7.0.0-beta.178",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "eve": "^0.12.0",
      "lucide-react": "^1.21.0",
      "next": "^16.2.9",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "tailwind-merge": "^3.3.1",
      "tailwindcss": "^4.3.1",
      "typescript": "^5.9.0",
      "zod": "^4.4.3"
    }
  },
  "scripts": {
    "dev": "turbo run dev --filter=@bookstore/web",
    "dev:admin": "turbo run dev --filter=@bookstore/admin",
    "dev:eve": "turbo run dev --filter=@bookstore/eve",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run format:check && turbo run lint typecheck test build",
    "db:seed": "bun --filter @bookstore/db seed",
    "db:push": "bun --filter @bookstore/db push",
    "db:setup": "bun --filter @bookstore/db setup",
    "db:generate": "bun --filter @bookstore/db generate",
    "db:migrate": "bun --filter @bookstore/db migrate"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.0.0",
    "turbo": "^2.0.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24 <27"
  },
  "packageManager": "bun@1.3.6"
}
